# ==========================================================================
# Olympus Agent Server - environment configuration
#
# TONIGHT: copy this file to ".env" (or leave it; mock mode needs nothing).
#   cp .env.example .env
# Everything runs fully offline in mock mode with ZERO keys and ZERO spend.
#
# DAY 2 (after you buy keys): set ADAPTER_MODE=real and fill in the keys for
# whichever adapters you want live. Each adapter falls back to a clear error
# if its key is missing, so you can flip them on one at a time.
# ==========================================================================

# Server
PORT=8787

# mock = no external calls, no cost (DEFAULT). real = use the keys below.
ADAPTER_MODE=mock

# --- Brains (Day 2) -------------------------------------------------------
# Anthropic API key powers Zeus / Oracle / Apollo reasoning when ADAPTER_MODE=real.
# Get one at https://console.anthropic.com  (pay-as-you-go, hard-cap it)
# ANTHROPIC_API_KEY=

# Model tiers (override only if you want; sensible defaults are built in)
# LLM_MODEL_FAST=claude-haiku-4-5
# LLM_MODEL_BALANCED=claude-sonnet-4-6
# LLM_MODEL_DEEP=claude-opus-4-8

# HARD ceiling on real LLM spend per calendar month (USD). When this month's
# tracked spend reaches the cap, every real model call is refused with a clear
# error until you raise it or the month rolls over. Mock mode is always free.
# LLM_MONTHLY_BUDGET_USD=20

# --- Apollo: art generation (Day 2) --------------------------------------
# One of: leonardo | ideogram | stability | local  (used only in real mode)
# ART_PROVIDER=
# ART_API_KEY=

# --- Apollo: Etsy + fulfillment (Day 2) ----------------------------------
# ETSY_API_KEY=
# ETSY_SHOP_ID=
# PRINTIFY_API_KEY=

# --- Oracle: optional paid market-intel (Day 2, free tier works without) --
# ERANK_API_KEY=
