# ==========================================================================
# Olympus Agent Server - environment configuration
#
# TONIGHT: copy this file to ".env" (or leave it; mock mode needs nothing).
#   cp .env.example .env
# Everything runs fully offline in mock mode with ZERO keys and ZERO spend.
#
# DAY 2 (after you buy keys): set ADAPTER_MODE=real and fill in the keys for
# whichever adapters you want live. Each adapter falls back to a clear error
# if its key is missing, so you can flip them on one at a time.
# ==========================================================================

# Server
PORT=8787

# mock = no external calls, no cost (DEFAULT). real = use the keys below.
ADAPTER_MODE=mock

# --- Brains (Day 2) -------------------------------------------------------
# Anthropic API key powers Zeus / Oracle / Apollo reasoning when ADAPTER_MODE=real.
# Get one at https://console.anthropic.com  (pay-as-you-go, hard-cap it)
# ANTHROPIC_API_KEY=

# Model tiers (override only if you want; sensible defaults are built in)
# LLM_MODEL_FAST=claude-haiku-4-5
# LLM_MODEL_BALANCED=claude-sonnet-4-6
# LLM_MODEL_DEEP=claude-opus-4-8

# HARD ceiling on real LLM spend per calendar month (USD). When this month's
# tracked spend reaches the cap, every real model call is refused with a clear
# error until you raise it or the month rolls over. Mock mode is always free.
# LLM_MONTHLY_BUDGET_USD=20

# --- Apollo: art generation (Day 2) --------------------------------------
# One of: leonardo | ideogram | stability | local  (used only in real mode)
# ART_PROVIDER=
# ART_API_KEY=

# --- Apollo: Etsy + fulfillment (Day 2) ----------------------------------
# ETSY_API_KEY=
# ETSY_SHOP_ID=
# PRINTIFY_API_KEY=

# --- Oracle: optional paid market-intel (Day 2, free tier works without) --
# ERANK_API_KEY=

# --- Zeus: ElevenLabs voice (independent of ADAPTER_MODE) -----------------
# Get a key at https://elevenlabs.io/app/settings/api-keys (free tier works for private use)
# ELEVENLABS_API_KEY=
# ZEUS_VOICE_ID=ljo9gAlSqKOvF6D8sOsX
# Voice Library voices require a paid plan (Starter+) for API access.
# ELEVENLABS_MODEL=eleven_flash_v2_5
# ELEVENLABS_SPEED=1.12
# ORACLE_VOICE_ID=HH3kybY6uEJ2ebSa9Vy3

# --- Treasury: project cost tracking --------------------------------------
# Subscriptions auto-accrue monthly into the treasury ledger on server start.
# CURSOR_SUBSCRIPTION_USD=20
# ELEVENLABS_SUBSCRIPTION_USD=5
# TREASURY_DRACHMA_USD_RATIO=1

# --- Linear: HQ task board (optional) -------------------------------------
# Get an API key at https://linear.app/settings/api
# LINEAR_API_KEY=
# LINEAR_DEFAULT_TEAM_ID=

# --- Tyche: cross-venue arb (Kalshi + ProphetX) ---------------------------
# TYCHE_MODE=observe
# TYCHE_STRATEGY=static_only
# TYCHE_AUTO_EXECUTION=true
# TYCHE_MAX_TRADE_USD=5
# TYCHE_MAX_DAILY_NOTIONAL_USD=50
# TYCHE_MIN_WORST_CASE_PROFIT_USD=0.25
# TYCHE_MIN_WORST_CASE_ROI=0.01
# TYCHE_MAX_SLIPPAGE=0.005
# TYCHE_MAX_ORDERBOOK_AGE_MS=1000
# TYCHE_MAX_LEG_DELAY_MS=500
# TYCHE_SCAN_INTERVAL_MS=5000
# KALSHI_ENV=demo
# KALSHI_API_KEY=
# KALSHI_API_SECRET=
# PROPHETX_ENV=sandbox
# PROPHETX_ACCESS_KEY=
# PROPHETX_SECRET_KEY=
# PROPHETX_BASE_URL=https://api-ss-sandbox.betprophet.co/partner
