{
  "name": "@olympus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "smoke:zeus": "tsx scripts/smoke-zeus.ts",
    "smoke:tyche": "tsx scripts/smoke-tyche.ts",
    "smoke:treasury": "tsx scripts/smoke-treasury.ts",
    "test:tyche": "tsx --test src/tyche/tyche.test.ts",
    "test:treasury": "tsx --test src/treasury/treasury.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@fastify/cors": "^11.2.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
