{
  "name": "olympus-opp-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Greek-gods-themed gamified command center for AI Opps (Mount Olympus overworld).",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "npm run dev --workspace apps/client",
    "dev:server": "npm run dev --workspace apps/server",
    "build": "npm run build --workspace apps/client",
    "preview": "npm run preview --workspace apps/client",
    "typecheck": "npm run typecheck --workspace apps/server && npm run typecheck --workspace apps/client",
    "validate:building": "node tools/validate_building_2_5d.mjs",
    "process:tyche-interior": "node tools/process_tyche_interior.mjs"
  },
  "devDependencies": {
    "@vercel/node": "^5.5.3",
    "concurrently": "^10.0.3",
    "sharp": "^0.35.2"
  }
}
